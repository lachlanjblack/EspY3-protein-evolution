import re

serotype_pattern = re.compile(r"O\d+(?::H\d+|:NM|:H-)?", re.IGNORECASE)

def extract_serotype(text: str | None) -> str | None:
    if not isinstance(text, str):
        return None
    m = serotype_pattern.search(text)
    if m:
        return m.group(0)
    return None

def extract_pathotype(text: str | None) -> str | None:
    if not isinstance(text, str):
        return None
    t = text.upper()
    for label in ["EHEC", "EPEC", "ETEC", "EAEC", "STEC", "UPEC", "APEC", "EIEC"]:
        if label in t:
            return label
    return None


def get_metadata_for_protein(pid, sleep=0.3):
    meta = {
        "protein_acc": pid,
        "nucleotide_acc": None,
        "organism": None,
        "strain": None,
        "isolation_source": None,
        "host": None,
        "country": None,
        "collection_date": None,
        "biosample": None,
        "serotype_inferred": None,
        "pathotype_inferred": None,
    }
    
    try:
        # 1) Fetch protein GenBank
        handle = Entrez.efetch(db="protein", id=pid, rettype="gb", retmode="text")
        record = SeqIO.read(handle, "genbank")
        handle.close()
        
        meta["organism"] = record.annotations.get("organism", None)
        description = record.description
        
        protein_source_feat = None
        cds_feat = None
        
        for feat in record.features:
            if feat.type == "source":
                protein_source_feat = feat
            elif feat.type == "CDS":
                cds_feat = feat
        
        # ---- Protein source qualifiers ----
        if protein_source_feat is not None:
            q = protein_source_feat.qualifiers
            if "strain" in q:
                meta["strain"] = q["strain"][0]
            if "isolation_source" in q:
                meta["isolation_source"] = q["isolation_source"][0]
            if "host" in q:
                meta["host"] = q["host"][0]
            if "country" in q:
                meta["country"] = q["country"][0]
            if "collection_date" in q:
                meta["collection_date"] = q["collection_date"][0]
            for xref in q.get("db_xref", []):
                if xref.startswith("BioSample:"):
                    meta["biosample"] = xref.split(":", 1)[1]
        
        # ---- coded_by → nucleotide accession ----
        nuc_acc = None
        if cds_feat is not None:
            coded_by = cds_feat.qualifiers.get("coded_by", [""])[0]
            if coded_by:
                # e.g., complement(CP021726.1:199117..200700)
                inside = coded_by
                if "(" in coded_by and ")" in coded_by:
                    inside = coded_by.split("(", 1)[1].split(")", 1)[0]
                nuc_acc = inside.split(":")[0]
                meta["nucleotide_acc"] = nuc_acc
        
        # If isolation_source is empty, try nucleotide record
        if nuc_acc and not meta["isolation_source"]:
            try:
                h = Entrez.efetch(db="nuccore", id=nuc_acc, rettype="gb", retmode="text")
                n_record = SeqIO.read(h, "genbank")
                h.close()
                
                for feat in n_record.features:
                    if feat.type == "source":
                        q = feat.qualifiers
                        if "strain" in q and not meta["strain"]:
                            meta["strain"] = q["strain"][0]
                        if "isolation_source" in q and not meta["isolation_source"]:
                            meta["isolation_source"] = q["isolation_source"][0]
                        if "host" in q and not meta["host"]:
                            meta["host"] = q["host"][0]
                        if "country" in q and not meta["country"]:
                            meta["country"] = q["country"][0]
                        if "collection_date" in q and not meta["collection_date"]:
                            meta["collection_date"] = q["collection_date"][0]
                        for xref in q.get("db_xref", []):
                            if xref.startswith("BioSample:") and not meta["biosample"]:
                                meta["biosample"] = xref.split(":", 1)[1]
                        break
            except Exception as e2:
                print(f"(Warning) nucleotide fetch failed for {pid} / {nuc_acc}: {e2}")
        
        # ---- Infer serotype and pathotype ----
        texts = [
            description,
            meta["organism"],
            meta["strain"],
            meta["isolation_source"],
        ]
        combined = " ".join([t for t in texts if isinstance(t, str)])
        
        meta["serotype_inferred"] = extract_serotype(combined)
        meta["pathotype_inferred"] = extract_pathotype(combined)
        
        time.sleep(sleep)
        return meta
    
    except Exception as e:
        print(f"ERROR for {pid}: {e}")
        time.sleep(sleep)
        return meta






